#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

command="${1:-}";
if [[ -z "${command}" ]]; then
  echo "Usage: ./newsctl {start|stop|restart|status|reset|pipeline|profile|import}"
  exit 1
fi

case "${command}" in
  start|stop|restart|status)
    uv run "${ROOT_DIR}/scripts/ui_service.py" "${command}"
    ;;
  reset)
    uv run "${ROOT_DIR}/scripts/ui_service.py" stop
    uv run "${ROOT_DIR}/scripts/ui_service.py" start
    ;;
  pipeline)
    uv run "${ROOT_DIR}/scripts/run_pipeline.py"
    ;;
  profile)
    uv run "${ROOT_DIR}/scripts/run_profiler.py"
    ;;
  import)
    shift
    uv run "${ROOT_DIR}/scripts/backfill_sitemaps.py" "$@"
    ;;
  *)
    echo "Unknown command: ${command}"
    echo "Usage: ./newsctl {start|stop|restart|status|reset|pipeline|profile|import}"
    exit 1
    ;;
 esac
